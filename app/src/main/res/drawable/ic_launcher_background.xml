<?xml version="1.0" encoding="utf-8"?>
<!--
    마음흐름 앱 아이콘 배경
    디자인: 하늘(파랑) → 파도(민트/티얼) → 석양(산호/복숭아) 그라디언트
            떠오르는 오렌지 태양 + 반짝이는 별 3개
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ① 배경: 하늘 파랑 → 따뜻한 산호/복숭아 그라디언트 -->
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54" android:startY="0"
                android:endX="54" android:endY="108"
                android:type="linear">
                <item android:offset="0"    android:color="#FF4AAEE4"/>
                <item android:offset="0.35" android:color="#FF7FCCE8"/>
                <item android:offset="0.58" android:color="#FFFABCA0"/>
                <item android:offset="1"    android:color="#FFF47860"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ② 태양 글로우 (연한 후광) -->
    <path android:pathData="M46,48 a21,21 0 1,0 42,0 a21,21 0 1,0 -42,0"
        android:fillColor="#60F4A060"/>

    <!-- ③ 태양 본체 (오렌지 원, 파도에 의해 아래 절반 가려짐) -->
    <path android:pathData="M52,48 a15,15 0 1,0 30,0 a15,15 0 1,0 -30,0"
        android:fillColor="#F4804C"/>

    <!-- ④ 뒤쪽 티얼/민트 파도 (태양이 여기서 솟아오름) -->
    <path android:pathData="M-2,50 C14,42 32,38 50,46 C60,51 66,50 78,40 C90,32 104,40 110,44 L110,110 L-2,110 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54" android:startY="38"
                android:endX="54" android:endY="110"
                android:type="linear">
                <item android:offset="0"   android:color="#FF86D8C8"/>
                <item android:offset="0.4" android:color="#FF5EC4B4"/>
                <item android:offset="1"   android:color="#FFF4B090"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ⑤ 크림/아이보리 하이라이트 파도 -->
    <path android:pathData="M-2,62 C16,56 34,60 54,58 C74,56 92,62 110,58 L110,110 L-2,110 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54" android:startY="56"
                android:endX="54" android:endY="110"
                android:type="linear">
                <item android:offset="0"   android:color="#D8F5E2D0"/>
                <item android:offset="0.4" android:color="#C0F4D8C0"/>
                <item android:offset="1"   android:color="#90F4B898"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ⑥ 앞쪽 복숭아/코랄 파도 -->
    <path android:pathData="M-2,72 C18,67 38,70 58,68 C78,66 96,72 110,68 L110,110 L-2,110 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54" android:startY="66"
                android:endX="54" android:endY="110"
                android:type="linear">
                <item android:offset="0"   android:color="#FFF5D8C0"/>
                <item android:offset="0.5" android:color="#FFF4B088"/>
                <item android:offset="1"   android:color="#FFF4906A"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- ⑦ 반짝이 별 1 (왼쪽 중간, 큰 별) -->
    <path
        android:pathData="M26,43 L27.8,38.2 L29.6,43 L34.4,44.8 L29.6,46.6 L27.8,51.4 L26,46.6 L21.2,44.8 Z"
        android:fillColor="#FFFFFBE8"/>

    <!-- ⑧ 반짝이 별 2 (왼쪽 위, 작은 별) -->
    <path
        android:pathData="M39,28 L40.2,24.4 L41.4,28 L45,29.2 L41.4,30.4 L40.2,34 L39,30.4 L35.4,29.2 Z"
        android:fillColor="#FFFFFBE8"/>

    <!-- ⑨ 반짝이 별 3 (오른쪽, 중간 크기 별) -->
    <path
        android:pathData="M88,36 L89.6,31.2 L91.2,36 L96,37.6 L91.2,39.2 L89.6,44 L88,39.2 L83.2,37.6 Z"
        android:fillColor="#FFFFFBE8"/>

</vector>
